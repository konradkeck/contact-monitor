APP_NAME=SalesOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8090

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=salesos
